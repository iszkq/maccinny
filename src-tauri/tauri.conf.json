{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MacCinny",
  "version": "1.4.7",
  "identifier": "com.iszkq.maccinny",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev -- --host 0.0.0.0",
    "devUrl": "http://localhost:8080",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MacCinny",
        "width": 1120,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPLOCALDATA/emoji-media-cache/**/*",
          "$APPLOCALDATA/desktop-media-cache-plain-v1/**/*",
          "$APPLOCALDATA/desktop-media-runtime-v1/**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
